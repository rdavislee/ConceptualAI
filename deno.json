{
    "imports": {
        "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^3.0.63",
        "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.52",
        "@ai-sdk/openai": "npm:@ai-sdk/openai@^3.0.47",
        "@ai-sdk/xai": "npm:@ai-sdk/xai@^3.0.73",
        "@concepts/": "./src/concepts/",
        "@concepts": "./src/concepts/concepts.ts",
        "@test-concepts": "./src/concepts/test_concepts.ts",
        "@utils/": "./src/utils/",
        "@engine": "./src/engine/mod.ts",
        "@syncs": "./src/syncs/syncs.ts",
        "freestyle-sandboxes": "npm:freestyle-sandboxes@^0.1.33",
        "ai": "npm:ai@^6.0.134",
        "mammoth": "npm:mammoth@^1",
        "pdf-parse": "npm:pdf-parse@^1"
    },
    "tasks": {
        "start": "deno run --env --allow-net --allow-write --allow-read --allow-sys --allow-env --allow-run src/main.ts",
        "concepts": "deno run --env --allow-net --allow-read --allow-sys --allow-env --allow-run src/concept_server.ts --port 8000 --baseUrl /api",
        "import": "deno run --env --allow-read --allow-write --allow-env src/utils/generate_imports.ts",
        "dyad-install": "cd src/concepts/FrontendGenerating/dyad && npm install",
        "build": "deno task dyad-install && deno task import && docker build -f Dockerfile.sandbox -t conceptualai-sandbox:latest ."
    },
    "lint": {
        "rules": {
            "exclude": [
                "no-import-prefix",
                "no-unversioned-import"
            ]
        }
    }
}
