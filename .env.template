# ==============================================================================
# ConceptualAI Environment Variables
# Copy this file to .env and fill in your values:  cp .env.template .env
# ==============================================================================

# --- Database (Required) ---
# For MongoDB Atlas, use mongodb+srv://. Encode special chars in password (e.g. % -> %25).
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=headlessconceptual

# --- Authentication (Required) ---
JWT_SECRET=your-jwt-secret-at-least-32-chars-long

# --- Server ---
PORT=8000
REQUESTING_BASE_URL=/api
REQUESTING_ALLOWED_DOMAIN=*
REQUESTING_SAVE_RESPONSES=true

# --- AI Runtime ---
# Generated concepts resolve provider/model from these env vars.
# Current internal concept flows should use Gemini synchronously, with Gemini Flash as the default model.
AI_PROVIDER=gemini
AI_MODEL=gemini-flash-latest
# Generated implementation/sync validation runs use these explicit test envs.
GENERATED_TEST_AI_PROVIDER=gemini
GENERATED_TEST_AI_MODEL=gemini-flash-latest
GENERATED_AI_CALL_TIMEOUT_MS=45000
GENERATED_CONCEPT_TEST_TIMEOUT_MS=60000
GENERATED_SYNC_TEST_TIMEOUT_MS=30000
GENERATED_SYNC_TEST_AI_TOUCHING_TIMEOUT_MS=120000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Gemini AI (Required for pipeline) ---
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_MODEL_FLASH=gemini-flash-latest
GEMINI_MODEL_PRO=gemini-3-pro-preview
GEMINI_CONFIG=./geminiConfig.json
# GEMINI_MODEL_PRO=gemini-1.5-pro
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIER_CHECK_MODEL=gemini-1.5-pro
# GEMINI_VERIFY_TIMEOUT_MS=8000
# GEMINI_VERIFY_CACHE_TTL_MS=300000
# GEMINI_VERIFY_FAILURE_CACHE_TTL_MS=60000

# --- Sandboxing ---
# Maximum number of concurrent sandbox containers allowed.
# When this limit is reached, new pipeline requests are rejected with a capacity error.
# Tune based on available RAM and CPU. See sandboxing-plan.md for sizing guidance.
MAX_CONCURRENT_SANDBOXES=20

# --- Concept Library ---
# URL of the concept-library server used by design and implementation retrieval.
# HEADLESS_URL=http://localhost:8000/api

# --- Frontend Generation ---
# If frontend generation later needs a browserless service URL, it should use its own dedicated env var.
