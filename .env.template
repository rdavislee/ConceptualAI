# ==============================================================================
# ConceptualAI Environment Variables
# Copy this file to .env and fill in your values:  cp .env.template .env
# ==============================================================================

# --- Database (Required) ---
MONGODB_URL=mongodb://localhost:27017
DB_NAME=conceptualai

# --- Authentication (Required) ---
JWT_SECRET=your-jwt-secret-here

# --- Server ---
PORT=8000
REQUESTING_BASE_URL=/api
REQUESTING_ALLOWED_DOMAIN=*
REQUESTING_SAVE_RESPONSES=false

# --- Gemini AI (Required for pipeline) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CONFIG=./geminiConfig.json
# GEMINI_MODEL_PRO=gemini-1.5-pro
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIER_CHECK_MODEL=gemini-1.5-pro
# GEMINI_VERIFY_TIMEOUT_MS=8000
# GEMINI_VERIFY_CACHE_TTL_MS=300000
# GEMINI_VERIFY_FAILURE_CACHE_TTL_MS=60000

# --- Sandboxing ---
# Maximum number of concurrent sandbox containers allowed.
# When this limit is reached, new pipeline requests are rejected with a capacity error.
# Tune based on available RAM and CPU. See sandboxing-plan.md for sizing guidance.
MAX_CONCURRENT_SANDBOXES=20

# --- Frontend Generation ---
# URL of a headless browser instance (e.g. Browserless) used by FrontendGenerating.
# Leave empty if not using frontend generation.
# HEADLESS_URL=http://localhost:3000

# --- Alternative AI Providers (Optional) ---
# AI_PROVIDER=gemini
# AI_MODEL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
