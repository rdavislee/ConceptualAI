      }
    },
    {
      "from": "post_detail",
      "trigger": "Add Comment",
      "action": "POST /posts/{postId}/comments",
      "on_success": {
        "type": "refresh_data",
        "target": "post_detail"
      }
    },
    {
      "from": "post_detail",
