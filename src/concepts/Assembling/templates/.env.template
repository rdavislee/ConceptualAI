# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# -----------------
# Database (Required)
# -----------------
# MongoDB connection string
MONGODB_URL=

# Database name
DB_NAME=

# -----------------
# Authentication (Required)
# -----------------
# JWT secret for session tokens (must be at least 32 characters)
# Generate one with: openssl rand -base64 32
JWT_SECRET=

# -----------------
# Server (Optional)
# -----------------
# Server port (default: 8000)
# PORT=8000

# API base URL path (default: /api)
# REQUESTING_BASE_URL=/api

# CORS allowed domain (default: * for all)
# Set to your frontend domain in production
# REQUESTING_ALLOWED_DOMAIN=https://your-frontend.com

# Request timeout in milliseconds (default: 300000 = 5 minutes)
# REQUESTING_TIMEOUT=300000
