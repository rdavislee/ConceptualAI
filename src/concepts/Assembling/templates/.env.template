# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# -----------------
# Database (Required)
# -----------------
# MongoDB connection string
MONGODB_URL=

# Database name
DB_NAME=

# -----------------
# Authentication (Required)
# -----------------
# JWT secret for session tokens (must be at least 32 characters)
# Generate one with: openssl rand -base64 32
JWT_SECRET=

# -----------------
# AI Runtime (Optional unless your app uses AI-backed concepts)
# -----------------
# Shared AI runtime defaults used by src/utils/ai.ts
AI_PROVIDER=gemini
AI_MODEL=gemini-flash-latest

# Optional runtime timeout for AI calls in milliseconds
# AI_TIMEOUT_MS=45000

# Provider API keys - set the one that matches AI_PROVIDER/AI_MODEL
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Common provider/model examples:
# AI_PROVIDER=gemini
# AI_MODEL=gemini-flash-latest
#
# AI_PROVIDER=openai
# AI_MODEL=gpt-4.1-mini
#
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-sonnet-latest
#
# AI_PROVIDER=xai
# AI_MODEL=grok-2-1212

# -----------------
# Server (Optional)
# -----------------
# Server port (default: 8000)
# PORT=8000

# API base URL path (default: /api)
# REQUESTING_BASE_URL=/api

# CORS allowed domain (default: * for all)
# Set to your frontend domain in production
# REQUESTING_ALLOWED_DOMAIN=https://your-frontend.com
